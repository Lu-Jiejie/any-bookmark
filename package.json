{
  "name": "any-bookmark",
  "type": "module",
  "version": "0.0.3",
  "private": true,
  "packageManager": "pnpm@11.8.0",
  "description": "为任何没有收藏功能的网站添加按域名分组的收藏夹面板。",
  "author": "Lu-Jiejie",
  "license": "MIT",
  "homepage": "https://github.com/Lu-Jiejie/any-bookmark",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lu-Jiejie/any-bookmark.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "release": "bumpp"
  },
  "dependencies": {
    "@vueuse/core": "^14.3.0",
    "unocss": "^66.7.2",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@iconify-json/mdi": "^1.2.3",
    "@unocss/eslint-plugin": "^66.7.2",
    "@unocss/transformer-directives": "^66.7.2",
    "@unocss/transformer-variant-group": "^66.7.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "bumpp": "^11.1.0",
    "eslint": "^10.5.0",
    "eslint-plugin-format": "^2.0.1",
    "nano-staged": "^1.0.2",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vite-plugin-monkey": "^8.0.0",
    "vue-tsc": "^3.2.8"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm nano-staged"
  },
  "nano-staged": {
    "*": "eslint --fix"
  }
}
